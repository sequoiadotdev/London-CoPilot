NEXT_PUBLIC_API_URL=http://localhost:5220
BACKEND_URL=http://localhost:5220
# Logo.dev publishable key (pk_...) — optional; enhances /api/logo when set
# Without it, logos are fetched via Google favicon v2 (free, no key)
# LOGO_DEV_PUBLISHABLE_KEY=pk_your_publishable_key
# LOGO_DEV_TOKEN (sk_...) is for paid REST APIs only — not used for logo images
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
